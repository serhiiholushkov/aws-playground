{
  "name": "infra",
  "version": "0.1.0",
  "bin": {
    "infra": "bin/infra.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "bootstrap": "dotenv -- cdk bootstrap",
    "synth": "dotenv -- cdk synth --all",
    "diff": "dotenv -- cdk diff --all",
    "deploy": "dotenv -- cdk deploy --all --require-approval never",
    "destroy": "dotenv -- cdk destroy --all"
  },
  "devDependencies": {
    "@types/jest": "^30",
    "@types/node": "^24.10.1",
    "jest": "^30",
    "ts-jest": "^29",
    "aws-cdk": "2.1117.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "dotenv-cli": "^11.0.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.247.0",
    "constructs": "^10.5.0"
  }
}
